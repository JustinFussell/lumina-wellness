<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#8B9A7D" />
    <title>@ViewData["Title"] — Lumina | Movement. Presence. Light.</title>
    
    <!-- Lumina Tailwind v4 (Play CDN for instant premium aesthetics during early dev) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'lumina-sage': '#8B9A7D',
              'lumina-cream': '#F7F4EF',
              'lumina-charcoal': '#2F2C27',
              'lumina-terracotta': '#B87D5C',
              'lumina-gold': '#C9A87C',
              'lumina-sage-light': '#E8EDE3',
              'lumina-warm-gray': '#EDE8DF',
            },
            fontFamily: {
              'serif-display': ['Georgia', 'serif'],
              'sans-elegant': ['Inter', 'system-ui', 'sans-serif'],
            },
            boxShadow: {
              'soft': '0 10px 30px -10px rgb(0 0 0 / 0.08), 0 4px 6px -1px rgb(0 0 0 / 0.05)',
              'glass': '0 8px 32px 0 rgb(31 38 135 / 0.07)',
            },
            animation: {
              'fade-in': 'fadeIn 0.6s ease-out forwards',
              'slide-up': 'slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards',
              'scale-in': 'scaleIn 0.3s ease-out forwards',
              'float': 'float 6s ease-in-out infinite',
            },
            keyframes: {
              fadeIn: {
                '0%': { opacity: '0' },
                '100%': { opacity: '1' },
              },
              slideUp: {
                '0%': { transform: 'translateY(20px)', opacity: '0' },
                '100%': { transform: 'translateY(0)', opacity: '1' },
              },
              scaleIn: {
                '0%': { transform: 'scale(0.96)', opacity: '0' },
                '100%': { transform: 'scale(1)', opacity: '1' },
              },
              float: {
                '0%, 100%': { transform: 'translateY(0)' },
                '50%': { transform: 'translateY(-8px)' },
              }
            }
          }
        }
      }
    </script>
    
    <!-- Lumina custom styles (works alongside CDN) -->
    <link rel="stylesheet" href="~/css/tailwind.output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
      /* === LUMINA MAXIMUM WOW DESIGN SYSTEM === */
      .glass {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.4);
      }
      
      .premium-card {
        transition: all 0.4s cubic-bezier(0.23, 1.0, 0.32, 1);
      }
      .premium-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.15);
      }
      
      .class-image {
        transition: transform 0.7s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .premium-card:hover .class-image {
        transform: scale(1.08);
      }
      
      .nav-link {
        position: relative;
        transition: color 0.2s ease;
      }
      .nav-link:after {
        content: '';
        position: absolute;
        width: 0;
        height: 1px;
        bottom: -2px;
        left: 0;
        background-color: #8B9A7D;
        transition: width 0.3s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .nav-link:hover:after {
        width: 100%;
      }
      
      .stagger-item {
        opacity: 0;
        animation: fadeIn 0.6s ease-out forwards;
      }
      
      .serene-gradient {
        background: linear-gradient(135deg, #F7F4EF 0%, #E8EDE3 100%);
      }
      
      .elegant-shadow {
        box-shadow: 0 20px 25px -5px rgb(47 44 39 / 0.08), 
                    0 8px 10px -6px rgb(47 44 39 / 0.08);
      }
      
      .smooth-modal {
        animation: scaleIn 0.2s cubic-bezier(0.23, 1, 0.32, 1);
      }

      /* Refined Buttons (plain CSS to keep Razor parser happy alongside Tailwind CDN) */
      .btn-lumina {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 1.5rem;
        font-weight: 500;
        transition: all 0.2s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .btn-lumina:active {
        transform: scale(0.985);
      }
      .btn-lumina-primary {
        background-color: #B87D5C;
        color: white;
        box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
      }
      .btn-lumina-primary:hover {
        background-color: #A36B4F;
      }
      .btn-lumina-secondary {
        border: 1px solid rgba(47, 44, 39, 0.8);
      }
      .btn-lumina-secondary:hover {
        background-color: #2F2C27;
        color: white;
      }

      /* Image Treatment */
      .wellness-image {
        transition: transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .group:hover .wellness-image {
        transform: scale(1.06);
      }

      /* Subtle Scroll Animations */
      .reveal {
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
    
    <!-- PWA + Icons (prepared) -->
    <link rel="manifest" href="~/manifest.json" />
</head>
<body class="bg-lumina-cream text-lumina-charcoal antialiased" data-logged-in="@(User.Identity?.IsAuthenticated == true ? "true" : "false")">
    <!-- Skip to content for accessibility -->
    <a href="#main-content" 
       class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-white px-4 py-2 rounded-2xl shadow z-50">
        Skip to main content
    </a>

    <header class="lumina-nav sticky top-0 z-40">
        <nav class="max-w-7xl mx-auto px-6">
            <div class="flex h-16 items-center justify-between">
                <!-- Logo -->
                <a asp-page="/Index" class="flex items-center gap-x-3 group">
                    <div class="w-9 h-9 rounded-2xl bg-lumina-sage flex items-center justify-center">
                        <span class="text-white text-xl font-light tracking-[-1.5px]">L</span>
                    </div>
                    <div>
                        <div class="font-semibold text-2xl tracking-tight text-lumina-charcoal group-hover:text-lumina-sage transition-colors">Lumina</div>
                        <div class="text-[10px] text-lumina-sage -mt-1.5 tracking-[1px]">RONDEBOSCH</div>
                    </div>
                </a>

                <!-- Desktop Nav -->
                <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
                    <a asp-page="/Index" class="hover:text-lumina-sage transition-colors">Home</a>
                    <a asp-page="/TheSpace" class="hover:text-lumina-sage transition-colors">The Space</a>
                    <a asp-page="/Teachers" class="hover:text-lumina-sage transition-colors">Teachers</a>
                    <a asp-page="/Schedule" class="hover:text-lumina-sage transition-colors">Schedule</a>
                    <a asp-page="/Pricing" class="hover:text-lumina-sage transition-colors">Pricing</a>
                    <a asp-page="/Account/Login" class="lumina-btn-ghost text-sm">Log in</a>
                    <a asp-page="/Account/Register" class="lumina-btn-primary text-sm">Begin your practice</a>
                </div>

                <!-- Mobile: simple CTA -->
                <div class="md:hidden">
                    <a asp-page="/Account/Register" class="lumina-btn-primary text-sm px-5 py-2">Join</a>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" role="main" class="min-h-[calc(100vh-4rem)]">
        @RenderBody()
    </main>

    <!-- Member Mobile Bottom Navigation - Premium Feel -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-xl border-t border-lumina-sage-light z-50 shadow-lg">
            <div class="flex justify-around items-center py-2 px-1 text-[10px] tracking-widest">
                <a asp-page="/App/Dashboard" class="flex flex-col items-center px-4 py-1 text-lumina-charcoal/70 hover:text-lumina-sage active:text-lumina-sage transition-colors">
                    <span class="text-xl mb-0.5">🏠</span>
                    <span class="font-medium">Home</span>
                </a>
                <a asp-page="/Schedule" class="flex flex-col items-center px-4 py-1 text-lumina-charcoal/70 hover:text-lumina-sage active:text-lumina-sage transition-colors">
                    <span class="text-xl mb-0.5">📅</span>
                    <span class="font-medium">Schedule</span>
                </a>
                <a asp-page="/App/Dashboard" class="flex flex-col items-center px-4 py-1 text-lumina-charcoal/70 hover:text-lumina-sage active:text-lumina-sage transition-colors">
                    <span class="text-xl mb-0.5">📈</span>
                    <span class="font-medium">Practice</span>
                </a>
                <a asp-page="/Account/Login" class="flex flex-col items-center px-4 py-1 text-lumina-charcoal/70 hover:text-lumina-sage active:text-lumina-sage transition-colors">
                    <span class="text-xl mb-0.5">👤</span>
                    <span class="font-medium">Me</span>
                </a>
            </div>
        </nav>
        
        <!-- Floating Book Button for extra delight on mobile -->
        <div class="md:hidden fixed bottom-20 right-5 z-50">
            <a asp-page="/Schedule" 
               class="flex items-center justify-center w-14 h-14 bg-lumina-terracotta text-white rounded-2xl shadow-2xl active:scale-95 transition-all">
                <span class="text-2xl">＋</span>
            </a>
        </div>
    }
    
    <footer class="border-t border-lumina-sage-light bg-white/60 mt-12">
        <div class="max-w-7xl mx-auto px-6 py-10 text-sm text-lumina-charcoal/70">
            <div class="flex flex-col md:flex-row justify-between gap-y-4">
                <div>
                    <span class="font-medium text-lumina-charcoal">Lumina</span> — Movement. Presence. Light.<br />
                    <span class="text-xs">Rondebosch, Cape Town • In the same building as physiotherapy care</span>
                </div>
                <div class="flex gap-x-6 text-xs">
                    <a href="#" class="hover:text-lumina-sage">Accessibility</a>
                    <a href="#" class="hover:text-lumina-sage">Our Approach</a>
                    <a asp-page="/Privacy" class="hover:text-lumina-sage">Privacy</a>
                </div>
            </div>
            <div class="mt-8 text-[10px] opacity-60">© 2026 Lumina Wellness Studio. Crafted with care for every body.</div>
        </div>
    </footer>

    <!-- HTMX + Alpine (CDN for rapid beautiful interactions) -->
    <script src="https://unpkg.com/htmx.org@2.0.2/dist/htmx.min.js"></script>
    <script src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js" defer></script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- PWA Service Worker Registration -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>