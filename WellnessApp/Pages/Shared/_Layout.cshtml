<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#8B9A7D" />
    <title>@ViewData["Title"] — Lumina | Movement. Presence. Light.</title>
    
    <!-- Lumina Tailwind v4 (Play CDN for instant premium aesthetics during early dev) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              'lumina-sage': '#8B9A7D',
              'lumina-cream': '#F7F4EF',
              'lumina-charcoal': '#2F2C27',
              'lumina-terracotta': '#B87D5C',
              'lumina-gold': '#C9A87C',
              'lumina-sage-light': '#E8EDE3',
              'lumina-warm-gray': '#EDE8DF',
            },
            fontFamily: {
              'serif-display': ['Georgia', 'serif'],
              'sans-elegant': ['Inter', 'system-ui', 'sans-serif'],
            },
            boxShadow: {
              'soft': '0 10px 30px -10px rgb(0 0 0 / 0.08), 0 4px 6px -1px rgb(0 0 0 / 0.05)',
              'glass': '0 8px 32px 0 rgb(31 38 135 / 0.07)',
            },
            animation: {
              'fade-in': 'fadeIn 0.6s ease-out forwards',
              'slide-up': 'slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards',
              'scale-in': 'scaleIn 0.3s ease-out forwards',
              'float': 'float 6s ease-in-out infinite',
            },
            keyframes: {
              fadeIn: {
                '0%': { opacity: '0' },
                '100%': { opacity: '1' },
              },
              slideUp: {
                '0%': { transform: 'translateY(20px)', opacity: '0' },
                '100%': { transform: 'translateY(0)', opacity: '1' },
              },
              scaleIn: {
                '0%': { transform: 'scale(0.96)', opacity: '0' },
                '100%': { transform: 'scale(1)', opacity: '1' },
              },
              float: {
                '0%, 100%': { transform: 'translateY(0)' },
                '50%': { transform: 'translateY(-8px)' },
              }
            }
          }
        }
      }
    </script>
    
    <!-- Lumina custom styles (works alongside CDN) -->
    <link rel="stylesheet" href="~/css/tailwind.output.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
      /* === LUMINA 2026 — REALLY MODERN DESIGN SYSTEM ===
         Crisp, layered, serene, high-end wellness product feel */
      :root {
        --ease-spring: cubic-bezier(0.22, 1.0, 0.3, 1);
        --ease-smooth: cubic-bezier(0.23, 1, 0.32, 1);
        --shadow-soft: 0 10px 30px -10px rgb(0 0 0 / 0.06), 0 4px 6px -1px rgb(0 0 0 / 0.04);
        --shadow-elevated: 0 25px 60px -14px rgb(47 44 39 / 0.13), 0 10px 22px -6px rgb(47 44 39 / 0.09);
        --shadow-glass: 0 8px 34px 0 rgb(31 38 135 / 0.07);
        --radius-xl: 1.25rem;
        --radius-2xl: 1.85rem;
      }

      .glass {
        background: rgba(255, 255, 255, 0.82);
        backdrop-filter: blur(26px);
        border: 1px solid rgba(255, 255, 255, 0.5);
      }

      /* Ultra-modern premium cards — deep layered elevation + crisp interaction */
      .premium-card {
        border: 1px solid rgba(139, 154, 125, 0.16);
        transition: transform 0.52s var(--ease-spring), 
                    box-shadow 0.52s var(--ease-smooth),
                    border-color 0.28s ease;
      }
      .premium-card:hover {
        transform: translateY(-12px) scale(1.006);
        box-shadow: var(--shadow-elevated);
        border-color: rgba(139, 154, 125, 0.32);
      }

      .class-image {
        transition: transform 0.85s var(--ease-spring);
      }
      .premium-card:hover .class-image {
        transform: scale(1.07);
      }

      .nav-link {
        position: relative;
        transition: color 0.2s ease;
      }
      .nav-link:after {
        content: '';
        position: absolute;
        width: 0;
        height: 1.5px;
        bottom: -3px;
        left: 0;
        background: linear-gradient(to right, #8B9A7D, #C9A87C);
        transition: width 0.38s var(--ease-smooth);
      }
      .nav-link:hover:after { width: 100%; }
      .nav-link.active:after { width: 100%; background: #8B9A7D; }

      .serene-gradient {
        background: linear-gradient(135deg, #F7F4EF 0%, #E8EDE3 100%);
      }

      .elegant-shadow { box-shadow: var(--shadow-soft); }

      .smooth-modal {
        animation: scaleIn 0.32s var(--ease-spring);
        box-shadow: var(--shadow-elevated);
      }

      /* 2026 Modern Buttons — tactile, refined, premium */
      .btn-lumina {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-2xl);
        font-weight: 500;
        letter-spacing: -0.015em;
        transition: all 0.26s var(--ease-smooth);
      }
      .btn-lumina:active { transform: scale(0.978); }

      .btn-lumina-primary {
        background: #B87D5C;
        color: white;
        box-shadow: 0 10px 22px -4px rgb(184 125 92 / 0.38);
      }
      .btn-lumina-primary:hover {
        background: #A36B4F;
        box-shadow: 0 14px 28px -4px rgb(184 125 92 / 0.42);
      }

      .btn-lumina-secondary {
        border: 1px solid rgba(47, 44, 39, 0.72);
        background: rgba(255,255,255,0.65);
        backdrop-filter: blur(10px);
      }
      .btn-lumina-secondary:hover {
        background: #2F2C27;
        color: white;
        border-color: #2F2C27;
      }

      .wellness-image {
        transition: transform 0.9s var(--ease-spring);
      }
      .group:hover .wellness-image {
        transform: scale(1.06);
      }

      /* === MODERN HEADER (crisp scroll behavior already in JS) === */
      .lumina-nav {
        background: rgba(247, 244, 239, 0.84);
        backdrop-filter: blur(18px);
        border-bottom: 1px solid rgba(139, 154, 125, 0.1);
        transition: all 0.38s var(--ease-smooth);
      }
      .lumina-nav.scrolled {
        background: rgba(247, 244, 239, 0.97);
        backdrop-filter: blur(28px);
        box-shadow: 0 10px 28px -14px rgb(47 44 39 / 0.09);
        border-bottom-color: rgba(139, 154, 125, 0.16);
      }
      .lumina-nav.scrolled .h-16 { height: 3.45rem; }

      /* Brand title already elevated from previous pass — keep strong */

      /* Really Modern Scroll Reveals — blur + scale + translate for premium 2026 motion */
      .reveal {
        opacity: 0;
        transform: translateY(34px) scale(0.982);
        filter: blur(3px);
        transition: all 0.72s var(--ease-spring);
        will-change: transform, opacity, filter;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0) scale(1);
        filter: blur(0);
      }
      .reveal-delay-1 { transition-delay: 95ms; }
      .reveal-delay-2 { transition-delay: 185ms; }
      .reveal-delay-3 { transition-delay: 275ms; }

      /* Very subtle modern grain for depth (barely perceptible) */
      .modern-grain {
        background-image: 
          linear-gradient(rgba(139,154,125,0.018) 1px, transparent 1px),
          linear-gradient(90deg, rgba(139,154,125,0.018) 1px, transparent 1px);
        background-size: 4px 4px;
        pointer-events: none;
      }

      /* Light parallax */
      .parallax-bg {
        transition: transform 0.08s linear;
        will-change: transform;
      }

      /* Modern subtle pointer-follow glow on cards (2026 micro-delight) */
      .premium-card {
        position: relative;
      }
      .premium-card::after {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), 
                    rgba(139,154,125,0.08) 0%, transparent 55%);
        opacity: 0;
        transition: opacity 0.4s ease;
        pointer-events: none;
        border-radius: inherit;
      }
      .premium-card:hover::after {
        opacity: 1;
      }
    </style>
    
    <!-- PWA + Icons (prepared) -->
    <link rel="manifest" href="~/manifest.json" />
</head>
<body class="bg-lumina-cream text-lumina-charcoal antialiased modern-grain" data-logged-in="@(User.Identity?.IsAuthenticated == true ? "true" : "false")">
    <!-- Skip to content for accessibility -->
    <a href="#main-content" 
       class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-white px-4 py-2 rounded-2xl shadow z-50">
        Skip to main content
    </a>

    <header id="main-header" class="lumina-nav sticky top-0 z-50 transition-all duration-300">
        <nav class="max-w-7xl mx-auto px-6">
            <div class="flex h-16 items-center justify-between transition-all duration-300">
                <!-- Premium Brand Title - stands out more, crisp & elegant -->
                <a asp-page="/Index" class="flex items-center gap-x-3.5 group">
                    <div class="w-10 h-10 rounded-2xl bg-lumina-sage flex items-center justify-center ring-1 ring-white/30 shadow-sm group-hover:scale-[1.03] transition-transform">
                        <span class="text-white text-2xl font-light tracking-[-2px]">L</span>
                    </div>
                    <div class="flex flex-col">
                        <div class="font-semibold text-[27px] md:text-[29px] tracking-[-1.25px] text-lumina-charcoal group-hover:text-lumina-sage transition-colors leading-none">Lumina</div>
                        <div class="flex items-center gap-x-1.5 -mt-0.5">
                            <div class="h-px w-3 bg-lumina-gold/60"></div>
                            <div class="text-[9.5px] text-lumina-sage tracking-[2.2px] font-medium">RONDEBOSCH</div>
                        </div>
                    </div>
                </a>

                <!-- Desktop Nav — Modern refined pill cluster (active state enhanced in JS for crisp feel) -->
                <div class="hidden md:flex items-center gap-x-1 text-sm font-medium bg-white/55 backdrop-blur-2xl rounded-3xl px-1.5 py-1 border border-lumina-sage-light/50" id="desktop-nav">
                    <a asp-page="/Index" class="nav-link px-4 py-1.5 rounded-2xl hover:bg-white/80 transition-colors" data-page="index">Home</a>
                    <a asp-page="/TheSpace" class="nav-link px-4 py-1.5 rounded-2xl hover:bg-white/80 transition-colors" data-page="thespace">The Space</a>
                    <a asp-page="/Teachers" class="nav-link px-4 py-1.5 rounded-2xl hover:bg-white/80 transition-colors" data-page="teachers">Teachers</a>
                    <a asp-page="/Schedule" class="nav-link px-4 py-1.5 rounded-2xl hover:bg-white/80 transition-colors" data-page="schedule">Schedule</a>
                    <a asp-page="/Pricing" class="nav-link px-4 py-1.5 rounded-2xl hover:bg-white/80 transition-colors" data-page="pricing">Pricing</a>
                    
                    <div class="w-px h-4 bg-lumina-sage-light/60 mx-1"></div>
                    
                    <a asp-page="/Account/Login" class="px-4 py-1.5 rounded-2xl hover:bg-white/80 text-xs tracking-widest transition-colors">Log in</a>
                    <a asp-page="/Account/Register" class="lumina-btn-primary px-5 py-1.5 text-xs tracking-widest">Begin</a>
                </div>

                <!-- Mobile: simple CTA -->
                <div class="md:hidden">
                    <a asp-page="/Account/Register" class="lumina-btn-primary text-sm px-5 py-2">Join</a>
                </div>
            </div>
        </nav>
    </header>

    <main id="main-content" role="main" class="min-h-[calc(100vh-4rem)]">
        @RenderBody()
    </main>

    <!-- Member Mobile Bottom Navigation - Premium Feel -->
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="md:hidden fixed bottom-0 left-0 right-0 bg-white/95 backdrop-blur-xl border-t border-lumina-sage-light z-50 shadow-lg">
            <div class="flex justify-around items-center py-2 px-1 text-[10px] tracking-widest">
                <a asp-page="/App/Dashboard" class="flex flex-col items-center px-4 py-1 text-lumina-charcoal/70 hover:text-lumina-sage active:text-lumina-sage transition-colors">
                    <span class="text-xl mb-0.5">🏠</span>
                    <span class="font-medium">Home</span>
                </a>
                <a asp-page="/Schedule" class="flex flex-col items-center px-4 py-1 text-lumina-charcoal/70 hover:text-lumina-sage active:text-lumina-sage transition-colors">
                    <span class="text-xl mb-0.5">📅</span>
                    <span class="font-medium">Schedule</span>
                </a>
                <a asp-page="/App/Dashboard" class="flex flex-col items-center px-4 py-1 text-lumina-charcoal/70 hover:text-lumina-sage active:text-lumina-sage transition-colors">
                    <span class="text-xl mb-0.5">📈</span>
                    <span class="font-medium">Practice</span>
                </a>
                <a asp-page="/Account/Login" class="flex flex-col items-center px-4 py-1 text-lumina-charcoal/70 hover:text-lumina-sage active:text-lumina-sage transition-colors">
                    <span class="text-xl mb-0.5">👤</span>
                    <span class="font-medium">Me</span>
                </a>
            </div>
        </nav>
        
        <!-- Floating Book Button for extra delight on mobile -->
        <div class="md:hidden fixed bottom-20 right-5 z-50">
            <a asp-page="/Schedule" 
               class="flex items-center justify-center w-14 h-14 bg-lumina-terracotta text-white rounded-2xl shadow-2xl active:scale-95 transition-all">
                <span class="text-2xl">＋</span>
            </a>
        </div>
    }
    
    <footer class="border-t border-lumina-sage-light bg-white/60 mt-12">
        <div class="max-w-7xl mx-auto px-6 py-10 text-sm text-lumina-charcoal/70">
            <div class="flex flex-col md:flex-row justify-between gap-y-4">
                <div>
                    <span class="font-medium text-lumina-charcoal">Lumina</span> — Movement. Presence. Light.<br />
                    <span class="text-xs">Rondebosch, Cape Town • In the same building as physiotherapy care</span>
                </div>
                <div class="flex gap-x-6 text-xs">
                    <a href="#" class="hover:text-lumina-sage">Accessibility</a>
                    <a href="#" class="hover:text-lumina-sage">Our Approach</a>
                    <a asp-page="/Privacy" class="hover:text-lumina-sage">Privacy</a>
                </div>
            </div>
            <div class="mt-8 text-[10px] opacity-60">© 2026 Lumina Wellness Studio. Crafted with care for every body.</div>
        </div>
    </footer>

    <!-- HTMX + Alpine (CDN for rapid beautiful interactions) -->
    <script src="https://unpkg.com/htmx.org@2.0.2/dist/htmx.min.js"></script>
    <script src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js" defer></script>
    
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- PWA Service Worker Registration -->
    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js');
        });
      }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>