@page
@{
    ViewData["Title"] = "Pricing";
}

<div class="max-w-5xl mx-auto px-6 py-16">
    <div class="text-center mb-11">
        <div class="text-[10px] tracking-[3.5px] text-lumina-sage">INVEST IN YOUR PRACTICE</div>
        <h1 class="text-5xl md:text-6xl font-light tracking-[-2px] mt-2">Simple, transparent pricing</h1>
        <p class="mt-3 text-lg text-lumina-charcoal/70 max-w-sm mx-auto">Choose the rhythm that fits your life.</p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
        <!-- 5 Class Pass -->
        <div class="premium-card lumina-card p-7 flex flex-col bg-white border border-lumina-sage-light/60">
            <div>
                <div class="text-lumina-terracotta text-xs tracking-[2.5px]">STARTER</div>
                <div class="text-3xl font-light tracking-tight mt-2">5-Class Pass</div>
                <div class="flex items-baseline mt-4">
                    <div class="text-5xl font-light tracking-tighter">R950</div>
                </div>
                <div class="text-xs text-lumina-charcoal/55">Valid 60 days</div>
            </div>
            <ul class="mt-7 space-y-2.5 text-sm flex-1 text-lumina-charcoal/80">
                <li class="flex items-start gap-x-2.5"><span class="text-lumina-sage mt-1 text-xs">→</span> Use across any class</li>
                <li class="flex items-start gap-x-2.5"><span class="text-lumina-sage mt-1 text-xs">→</span> Share with a friend</li>
                <li class="flex items-start gap-x-2.5"><span class="text-lumina-sage mt-1 text-xs">→</span> Perfect for trying us out</li>
            </ul>
            <a asp-page="/Account/Register" class="mt-7 btn-lumina btn-lumina-primary w-full py-3 text-sm">Get started</a>
        </div>

        <!-- 10 Class Pass — Most Popular, elevated -->
        <div class="premium-card lumina-card p-7 flex flex-col bg-white border-2 border-lumina-sage relative shadow-sm">
            <div class="absolute -top-2.5 right-5 bg-lumina-sage text-white text-[9px] px-3.5 py-1 rounded-full tracking-widest">MOST POPULAR</div>
            <div>
                <div class="text-lumina-terracotta text-xs tracking-[2.5px]">COMMITTED</div>
                <div class="text-3xl font-light tracking-tight mt-2">10-Class Pass</div>
                <div class="flex items-baseline mt-4">
                    <div class="text-5xl font-light tracking-tighter">R1,750</div>
                </div>
                <div class="text-xs text-lumina-charcoal/55">Valid 90 days</div>
            </div>
            <ul class="mt-7 space-y-2.5 text-sm flex-1 text-lumina-charcoal/80">
                <li class="flex items-start gap-x-2.5"><span class="text-lumina-sage mt-1 text-xs">→</span> Best value per class</li>
                <li class="flex items-start gap-x-2.5"><span class="text-lumina-sage mt-1 text-xs">→</span> Flexible scheduling</li>
                <li class="flex items-start gap-x-2.5"><span class="text-lumina-sage mt-1 text-xs">→</span> Pause up to 14 days</li>
            </ul>
            <a asp-page="/Account/Register" class="mt-7 btn-lumina btn-lumina-primary w-full py-3 text-sm">Choose this pass</a>
        </div>

        <!-- Monthly Unlimited -->
        <div class="premium-card lumina-card p-7 flex flex-col bg-white border border-lumina-sage-light/60">
            <div>
                <div class="text-lumina-terracotta text-xs tracking-[2.5px]">UNLIMITED</div>
                <div class="text-3xl font-light tracking-tight mt-2">Monthly Unlimited</div>
                <div class="flex items-baseline mt-4">
                    <div class="text-5xl font-light tracking-tighter">R1,850</div>
                </div>
                <div class="text-xs text-lumina-charcoal/55">Billed monthly • Cancel anytime</div>
            </div>
            <ul class="mt-7 space-y-2.5 text-sm flex-1 text-lumina-charcoal/80">
                <li class="flex items-start gap-x-2.5"><span class="text-lumina-sage mt-1 text-xs">→</span> Unlimited classes</li>
                <li class="flex items-start gap-x-2.5"><span class="text-lumina-sage mt-1 text-xs">→</span> Priority booking</li>
                <li class="flex items-start gap-x-2.5"><span class="text-lumina-sage mt-1 text-xs">→</span> Guest passes included</li>
            </ul>
            <a asp-page="/Account/Register" class="mt-7 btn-lumina btn-lumina-primary w-full py-3 text-sm">Start unlimited</a>
        </div>
    </div>

    <div class="text-center mt-10 text-xs text-lumina-charcoal/55 tracking-widest">
        All packages include full schedule access and the same beautiful experience.<br>
        Gift cards &amp; corporate rates available.
    </div>
</div>