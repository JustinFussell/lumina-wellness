@page
@model Lumina.Pages.Admin.IndexModel
@using Lumina.Data
@{
    ViewData["Title"] = "Studio Dashboard";
}

<div class="max-w-7xl mx-auto px-6 py-8">
    <div class="flex items-center justify-between mb-8">
        <div>
            <div class="uppercase tracking-[3px] text-xs text-lumina-sage">OWNER TOOLS</div>
            <h1 class="section-title text-5xl tracking-tight">Studio Dashboard</h1>
        </div>
        <div class="text-right">
            <div class="text-xs text-lumina-charcoal/60">Lumina Rondebosch</div>
            <div class="text-sm text-lumina-sage">@DateTime.Now.ToString("dddd, dd MMM")</div>
        </div>
    </div>

    <!-- KPIs - Premium Owner View -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
        <div class="lumina-card p-6 group">
            <div class="flex items-center gap-x-3">
                <div class="w-9 h-9 rounded-2xl bg-lumina-sage-light flex items-center justify-center text-lumina-sage">📅</div>
                <div>
                    <div class="text-xs uppercase tracking-widest text-lumina-sage">Today’s Classes</div>
                    <div class="text-5xl font-light tracking-tighter mt-1 group-hover:text-lumina-sage transition-colors">@Model.TodaysClasses</div>
                </div>
            </div>
            <div class="mt-4 text-sm text-lumina-charcoal/60">@Model.TodaysSpotsLeft spots remaining</div>
        </div>

        <div class="lumina-card p-6 group">
            <div class="flex items-center gap-x-3">
                <div class="w-9 h-9 rounded-2xl bg-lumina-sage-light flex items-center justify-center text-lumina-sage">📊</div>
                <div>
                    <div class="text-xs uppercase tracking-widest text-lumina-sage">Occupancy</div>
                    <div class="text-5xl font-light tracking-tighter mt-1 group-hover:text-lumina-sage transition-colors">@Model.TodayOccupancy<span class="text-3xl">%</span></div>
                </div>
            </div>
            <div class="mt-4 text-sm text-lumina-charcoal/60">Average across all classes</div>
        </div>

        <div class="lumina-card p-6 group">
            <div class="flex items-center gap-x-3">
                <div class="w-9 h-9 rounded-2xl bg-lumina-sage-light flex items-center justify-center text-lumina-sage">🧘</div>
                <div>
                    <div class="text-xs uppercase tracking-widest text-lumina-sage">Active Members</div>
                    <div class="text-5xl font-light tracking-tighter mt-1 group-hover:text-lumina-sage transition-colors">@Model.ActiveMembers</div>
                </div>
            </div>
            <div class="mt-4 text-sm text-lumina-charcoal/60">Practiced in the last 30 days</div>
        </div>

        <div class="lumina-card p-6 group">
            <div class="flex items-center gap-x-3">
                <div class="w-9 h-9 rounded-2xl bg-lumina-sage-light flex items-center justify-center text-lumina-sage">💳</div>
                <div>
                    <div class="text-xs uppercase tracking-widest text-lumina-sage">Credits Sold (30d)</div>
                    <div class="text-5xl font-light tracking-tighter mt-1 group-hover:text-lumina-sage transition-colors">@Model.CreditsIssued30d</div>
                </div>
            </div>
            <div class="mt-4 text-sm text-lumina-charcoal/60">Total credits purchased</div>
        </div>
    </div>

    <!-- Today's Classes - Premium Table -->
    <div class="mb-10">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-2xl font-medium tracking-tight">Today’s Classes</h2>
            <a asp-page="/Admin/Schedule" class="text-sm text-lumina-sage hover:text-lumina-terracotta">Manage full schedule →</a>
        </div>
        
        <div class="lumina-card overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-lumina-sage-light/30 text-lumina-charcoal/60">
                        <th class="text-left px-6 py-3 font-normal">Time &amp; Class</th>
                        <th class="text-left px-6 py-3 font-normal">Instructor</th>
                        <th class="text-center px-6 py-3 font-normal">Capacity</th>
                        <th class="text-right px-6 py-3 font-normal w-40">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y">
                    @foreach (var cls in Model.TodaysScheduledClasses)
                    {
                        <tr class="hover:bg-lumina-sage-light/20 transition-colors">
                            <td class="px-6 py-4">
                                <div class="font-medium">@cls.StartUtc.ToString("HH:mm")</div>
                                <div class="text-lumina-charcoal/70">@cls.ClassType.Name</div>
                            </td>
                            <td class="px-6 py-4 text-lumina-charcoal/80">@cls.Instructor.Name</td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-center gap-x-2">
                                    <div class="w-16 h-1.5 bg-lumina-sage-light rounded-full overflow-hidden">
                                        <div class="h-full bg-lumina-sage rounded-full" 
                                             style="width: @((cls.Bookings.Count(b => b.Status != BookingStatus.Cancelled) * 100.0 / cls.EffectiveCapacity))%"></div>
                                    </div>
                                    <span class="text-xs tabular-nums text-lumina-charcoal/70 w-8 text-right">
                                        @cls.Bookings.Count(b => b.Status != BookingStatus.Cancelled)/@cls.EffectiveCapacity
                                    </span>
                                </div>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <a asp-page="/Admin/Attendance" asp-route-id="@cls.Id" 
                                   class="inline-flex items-center gap-x-1.5 text-sm px-4 py-1.5 rounded-2xl border border-lumina-sage-light hover:bg-lumina-sage hover:text-white hover:border-lumina-sage transition-all">
                                    Take Attendance
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
        <!-- Quick Members -->
        <div>
            <h2 class="text-2xl font-medium mb-4">Recent Members</h2>
            <div class="lumina-card p-5">
                @if (Model.RecentMembers.Any())
                {
                    <ul class="space-y-3 text-sm">
                        @foreach (var m in Model.RecentMembers)
                        {
                            <li class="flex justify-between">
                                <span>@m.FullName</span>
                                <span class="text-lumina-charcoal/60">@m.Email</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-lumina-charcoal/60">No members yet.</p>
                }
            </div>
        </div>

        <!-- Quick Actions -->
        <div>
            <h2 class="text-2xl font-medium mb-4">Quick Actions</h2>
            <div class="lumina-card p-5 space-y-3 text-sm">
                <a asp-page="/Admin/Schedule" class="block hover:text-lumina-terracotta">→ Manage full schedule</a>
                <a asp-page="/Admin/Members" class="block hover:text-lumina-terracotta">→ View all members</a>
                <a asp-page="/Admin/Reports" class="block hover:text-lumina-terracotta">→ View reports</a>
            </div>
        </div>
    </div>
</div>