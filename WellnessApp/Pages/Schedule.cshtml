@page
@model Lumina.Pages.ScheduleModel
@{
    ViewData["Title"] = "Class Schedule";
}

<div class="max-w-7xl mx-auto px-6 py-12">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
        <div>
            <div class="uppercase tracking-[3px] text-xs text-lumina-sage">RONDEBOSCH • CAPE TOWN</div>
            <h1 class="section-title text-5xl tracking-tight mt-2">The Schedule</h1>
            <p class="mt-3 max-w-md text-lumina-charcoal/70">
                Move when it feels right. Every class is designed with care, modifications, and genuine welcome for all bodies.
            </p>
        </div>
        
        <div class="flex gap-3">
            <a asp-page="/Account/Register" class="lumina-btn-primary">Join as a member</a>
        </div>
    </div>

    <!-- Filters (simplified for initial build) -->
    <div class="lumina-card p-6 mb-8">
        <p class="text-sm text-lumina-charcoal/70">
            Dynamic filters coming in the next update. For now, enjoy the beautiful class cards with real seeded data from our Rondebosch studio.
        </p>
    </div>

    <!-- Schedule Grid -->
    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        @foreach (var cls in Model.UpcomingClasses)
        {
            <div class="class-card lumina-card group flex flex-col overflow-hidden">
                <div class="px-6 pt-6 pb-4 flex-1">
                    <div class="flex items-start justify-between">
                        <div>
                            <div class="text-xs uppercase tracking-[2px] text-lumina-sage">@cls.ClassType.Level</div>
                            <h3 class="text-2xl font-medium tracking-tight mt-1">@cls.ClassType.Name</h3>
                        </div>
                        <div class="text-right text-sm">
                            <div class="font-medium">@cls.StartUtc.ToString("ddd")</div>
                            <div class="text-lumina-charcoal/60">@cls.StartUtc.ToString("HH:mm")</div>
                        </div>
                    </div>

                    <div class="mt-4 flex items-center gap-x-2 text-sm">
                        <span class="text-lumina-charcoal/70">with</span>
                        <span class="font-medium">@cls.Instructor.Name</span>
                    </div>

                    <p class="mt-4 text-[15px] text-lumina-charcoal/80 leading-relaxed line-clamp-3">
                        @cls.ClassType.Description
                    </p>

                    @if (!string.IsNullOrEmpty(cls.ClassType.AccessFeatures))
                    {
                        <div class="mt-4 flex flex-wrap gap-1.5">
                            @foreach (var feature in cls.ClassType.AccessFeatures.Split('•', StringSplitOptions.RemoveEmptyEntries).Take(3))
                            {
                                <span class="inline-block rounded-full bg-lumina-sage-light px-3 py-0.5 text-xs text-lumina-charcoal/80">@feature.Trim()</span>
                            }
                        </div>
                    }
                </div>

                <div class="border-t border-lumina-sage-light px-6 py-4 flex items-center justify-between bg-white/50">
                    <div>
                        <div class="text-xs text-lumina-charcoal/60">Spots left</div>
                        <div class="font-medium">@(cls.EffectiveCapacity - cls.Bookings.Count) / @cls.EffectiveCapacity</div>
                    </div>

                    <a asp-page="/Account/Register" 
                       class="lumina-btn-primary text-sm px-6 py-2 group-hover:bg-lumina-terracotta transition-colors">
                        Book class
                    </a>
                </div>
            </div>
        }
    </div>

    <div class="mt-12 text-center text-sm text-lumina-charcoal/60">
        More classes added weekly. <a asp-page="/Account/Register" class="text-lumina-sage hover:underline">Become a member</a> for full access and priority booking.
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js" defer></script>
}