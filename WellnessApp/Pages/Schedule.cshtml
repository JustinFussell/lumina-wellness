@page
@model Lumina.Pages.ScheduleModel
@using Lumina.Data
@{
    ViewData["Title"] = "Class Schedule";
}

<div class="max-w-7xl mx-auto px-6 py-12" x-data="schedulePage()">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
        <div>
            <div class="uppercase tracking-[3px] text-xs text-lumina-sage">RONDEBOSCH • CAPE TOWN</div>
            <h1 class="section-title text-6xl tracking-[-1.5px] mt-2">The Schedule</h1>
            <p class="mt-3 max-w-md text-xl text-lumina-charcoal/70">
                Move when it feels right. Every class is designed with care for all bodies.
            </p>
        </div>
        
        <div>
            <a asp-page="/Account/Register" class="lumina-btn-primary text-base px-8 py-3">Become a member</a>
        </div>
    </div>

    <!-- Beautiful Filters -->
    <div class="flex flex-wrap items-center gap-2 mb-8">
        <div class="text-sm text-lumina-charcoal/60 mr-2">Filter by:</div>
        <button @click="filter = ''" 
                :class="{ 'bg-lumina-sage text-white': filter === '', 'bg-lumina-sage-light hover:bg-lumina-sage-light/80': filter !== '' }"
                class="px-5 py-1.5 text-sm rounded-2xl transition-all">All</button>
        
        <button @click="filter = 'Pilates'" 
                :class="{ 'bg-lumina-sage text-white': filter === 'Pilates' }"
                class="px-5 py-1.5 text-sm rounded-2xl bg-lumina-sage-light hover:bg-lumina-sage-light/80 transition-all">Pilates</button>
        
        <button @click="filter = 'Yoga'" 
                :class="{ 'bg-lumina-sage text-white': filter === 'Yoga' }"
                class="px-5 py-1.5 text-sm rounded-2xl bg-lumina-sage-light hover:bg-lumina-sage-light/80 transition-all">Yoga</button>
        
        <button @click="filter = 'Beginner'" 
                :class="{ 'bg-lumina-sage text-white': filter === 'Beginner' }"
                class="px-5 py-1.5 text-sm rounded-2xl bg-lumina-sage-light hover:bg-lumina-sage-light/80 transition-all">Beginner Friendly</button>
    </div>

    <!-- Stunning Schedule Grid -->
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        @foreach (var cls in Model.UpcomingClasses)
        {
            var imageUrl = cls.ClassType.Modalities.Contains("Yoga") 
                ? "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=800" 
                : "https://images.unsplash.com/photo-1518611012118-696072aa579a?q=80&w=800";

            <div x-show="matchesFilter('@cls.ClassType.Modalities', '@cls.ClassType.Level')"
                 class="premium-card group bg-white rounded-3xl overflow-hidden elegant-shadow border border-lumina-sage-light/40 cursor-pointer"
                 @click="openModal(@cls.Id, '@cls.ClassType.Name', '@cls.Instructor.Name', '@cls.StartUtc.ToString("f")', '@cls.ClassType.Description', '@cls.ClassType.AccessFeatures', @cls.EffectiveCapacity, @cls.Bookings.Count(b => b.Status != BookingStatus.Cancelled))">
                
                <!-- Image Header -->
                <div class="relative h-52 overflow-hidden">
                    <img src="@imageUrl" 
                         class="class-image w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                         alt="@cls.ClassType.Name in serene studio">
                    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/20 to-black/70"></div>
                    
                    <!-- Top badges -->
                    <div class="absolute top-4 left-4 flex gap-2">
                        <span class="px-3 py-1 text-xs font-medium bg-white/90 text-lumina-charcoal rounded-full">@cls.ClassType.Level</span>
                    </div>
                    
                    <div class="absolute bottom-4 left-4 right-4">
                        <div class="text-white">
                            <div class="text-sm opacity-80">@cls.StartUtc.ToString("ddd") • @cls.StartUtc.ToString("HH:mm")</div>
                            <h3 class="text-2xl font-medium tracking-tight leading-none mt-1">@cls.ClassType.Name</h3>
                        </div>
                    </div>
                </div>

                <div class="p-5">
                    <div class="flex items-center justify-between text-sm">
                        <div class="flex items-center gap-x-2">
                            <span class="text-lumina-charcoal/60">with</span>
                            <span class="font-medium">@cls.Instructor.Name</span>
                        </div>
                        
                        <!-- Capacity -->
                        <div class="flex items-center gap-x-2">
                            <div class="text-xs text-lumina-charcoal/60">Spots</div>
                            <div class="font-medium text-sm">@(cls.EffectiveCapacity - cls.Bookings.Count(b => b.Status != BookingStatus.Cancelled))</div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(cls.ClassType.AccessFeatures))
                    {
                        <div class="mt-4 flex flex-wrap gap-1.5">
                            @foreach (var feature in cls.ClassType.AccessFeatures.Split('•', StringSplitOptions.RemoveEmptyEntries).Take(2))
                            {
                                <span class="text-[10px] px-2.5 py-0.5 rounded-full bg-lumina-sage-light text-lumina-charcoal/90">@feature.Trim()</span>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="mt-16 text-center text-sm text-lumina-charcoal/60">
        New classes added every week. <a asp-page="/Account/Register" class="text-lumina-sage hover:underline font-medium">Become a member</a> for priority booking.
    </div>
</div>

<!-- Beautiful Class Detail Modal -->
<div x-show="modalOpen" 
     x-transition:enter="transition ease-out duration-200"
     x-transition:enter-start="opacity-0"
     x-transition:enter-end="opacity-100"
     class="fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
     @click="closeModal()">
    
    <div @click.stop 
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 translate-y-4 scale-95"
         x-transition:enter-end="opacity-100 translate-y-0 scale-100"
         class="smooth-modal w-full max-w-lg bg-white rounded-3xl overflow-hidden elegant-shadow">
        
        <div class="relative h-64">
            <img :src="modalImage" class="w-full h-full object-cover" alt="">
            <div class="absolute inset-0 bg-gradient-to-b from-black/30 to-black/70"></div>
            
            <button @click="closeModal()" 
                    class="absolute top-5 right-5 w-9 h-9 flex items-center justify-center text-white bg-black/40 hover:bg-black/60 rounded-full transition">
                ✕
            </button>
            
            <div class="absolute bottom-5 left-6 text-white">
                <div class="text-sm opacity-80" x-text="modalTime"></div>
                <div class="text-3xl font-medium tracking-tight" x-text="modalTitle"></div>
            </div>
        </div>

        <div class="p-6" x-show="!bookingSuccess">
            <div class="flex items-center gap-x-2 text-sm mb-4">
                <span class="text-lumina-charcoal/60">with</span>
                <span class="font-medium text-lg" x-text="modalInstructor"></span>
            </div>

            <p class="text-lumina-charcoal/80 leading-relaxed" x-text="modalDescription"></p>

            <div class="my-6">
                <div class="text-xs uppercase tracking-widest text-lumina-sage mb-2">Accessibility &amp; Modifications</div>
                <div class="text-sm text-lumina-charcoal/80 whitespace-pre-line" x-text="modalAccess"></div>
            </div>

            <div class="flex items-center justify-between border-t pt-5">
                <div>
                    <div class="text-xs text-lumina-charcoal/60">Spots remaining</div>
                    <div class="font-semibold text-xl" x-text="modalSpots + ' / ' + modalCapacity"></div>
                </div>

                <button @click="bookFromModal()" 
                        :disabled="bookingInProgress"
                        class="lumina-btn-primary px-9 py-3 text-base disabled:opacity-70 flex items-center gap-2">
                    <span x-show="!bookingInProgress">Book this class</span>
                    <span x-show="bookingInProgress" class="flex items-center gap-2">
                        <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Securing your spot...
                    </span>
                </button>
            </div>
        </div>

        <!-- Beautiful Success State -->
        <div x-show="bookingSuccess" class="p-8 text-center">
            <div class="mx-auto w-16 h-16 rounded-full bg-lumina-sage-light flex items-center justify-center mb-6">
                <svg class="w-8 h-8 text-lumina-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
                </svg>
            </div>
            
            <div class="text-2xl font-medium tracking-tight mb-2">You're in.</div>
            <p class="text-lumina-charcoal/70 mb-8">Your spot in <span class="font-medium" x-text="modalTitle"></span> is confirmed.</p>

            <div class="flex flex-col gap-3">
                <button @click="viewInDashboard()" 
                        class="w-full lumina-btn-primary py-3">
                    View in My Practice
                </button>
                <button @click="closeModal()" 
                        class="w-full text-sm py-2 text-lumina-charcoal/70 hover:text-lumina-charcoal transition">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js" defer></script>
    
    <script>
    function schedulePage() {
      return {
        filter: '',
        modalOpen: false,
        modalTitle: '',
        modalInstructor: '',
        modalTime: '',
        modalDescription: '',
        modalAccess: '',
        modalCapacity: 0,
        modalSpots: 0,
        modalImage: '',
        modalClassId: 0,
        bookingInProgress: false,
        bookingSuccess: false,

        matchesFilter(modalities, level) {
          if (!this.filter) return true;
          if (this.filter === 'Pilates' && modalities.includes('Pilates')) return true;
          if (this.filter === 'Yoga' && modalities.includes('Yoga')) return true;
          if (this.filter === 'Beginner' && level.includes('Beginner')) return true;
          return false;
        },

        openModal(id, title, instructor, time, description, access, capacity, booked) {
          this.modalClassId = id;
          this.modalTitle = title;
          this.modalInstructor = instructor;
          this.modalTime = time;
          this.modalDescription = description;
          this.modalAccess = access || 'Modifications available for most bodies.';
          this.modalCapacity = capacity;
          this.modalSpots = capacity - booked;
          this.modalImage = (title.toLowerCase().includes('yoga') || title.toLowerCase().includes('restorative')) 
            ? 'https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=800' 
            : 'https://images.unsplash.com/photo-1518611012118-696072aa579a?q=80&w=800';
          this.bookingSuccess = false;
          this.modalOpen = true;
        },

        closeModal() {
          this.modalOpen = false;
          // Reset success state when closing
          setTimeout(() => {
            this.bookingSuccess = false;
          }, 300);
        },

        async bookFromModal() {
          // If not logged in, redirect nicely
          if (!document.querySelector('meta[name="user-logged-in"]') && !window.LuminaUserLoggedIn) {
            // For demo purposes, we'll show a nice message and redirect
            window.location.href = '/Account/Register?returnUrl=/Schedule';
            return;
          }

          this.bookingInProgress = true;

          // Simulate smooth booking (in real app this would be HTMX or fetch to the handler)
          // For now, we'll use a timeout to simulate and then show success
          setTimeout(() => {
            this.bookingInProgress = false;
            this.bookingSuccess = true;
            
            // In a real implementation, we would submit the actual form here
            // and update modalSpots on success
          }, 850);
        },

        viewInDashboard() {
          window.location.href = '/App/Dashboard';
        }
      }
    }
    </script>
}