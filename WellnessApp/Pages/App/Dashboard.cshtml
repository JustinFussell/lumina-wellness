@page
@model Lumina.Pages.App.DashboardModel
@{
    ViewData["Title"] = "My Practice";
}

<div class="max-w-5xl mx-auto px-6 py-10">
    <div class="flex items-center justify-between mb-8">
        <div>
            <div class="text-sm text-lumina-sage tracking-widest">YOUR PRACTICE</div>
            <h1 class="section-title text-5xl tracking-tight mt-1">Good to see you, @User.Identity?.Name?.Split(' ').FirstOrDefault().</h1>
        </div>
        <a asp-page="/Schedule" class="hidden md:block btn-lumina btn-lumina-primary px-8">Book your next class</a>
    </div>

    <!-- Streak + Visual Stats -->
    <div class="grid md:grid-cols-12 gap-5 mb-8">
        <div class="md:col-span-5 lumina-card p-8 flex flex-col justify-center">
            <div class="flex items-baseline gap-x-3">
                <div class="text-[92px] font-light tracking-tighter leading-none text-lumina-sage">12</div>
                <div>
                    <div class="text-2xl font-medium">day streak</div>
                    <div class="text-sm text-lumina-charcoal/70">Keep it going</div>
                </div>
            </div>
            <div class="mt-auto pt-8 text-sm text-lumina-charcoal/60">Your longest streak this year is 19 days. You're in a beautiful rhythm.</div>
        </div>

        <div class="md:col-span-7 grid grid-cols-2 gap-5">
            <div class="lumina-card p-7">
                <div class="text-xs uppercase tracking-widest text-lumina-sage mb-1">This month</div>
                <div class="text-6xl font-light tracking-tighter">@Model.ThisMonthClasses</div>
                <div class="text-lumina-charcoal/70">classes moved through</div>
                <div class="mt-6 h-2 bg-lumina-sage-light rounded-full overflow-hidden">
                    <div class="h-2 bg-lumina-sage w-3/4 rounded-full"></div>
                </div>
            </div>
            <div class="lumina-card p-7">
                <div class="text-xs uppercase tracking-widest text-lumina-sage mb-1">Credits</div>
                <div class="text-6xl font-light tracking-tighter">@Model.CreditsRemaining</div>
                <div class="text-lumina-charcoal/70">remaining</div>
                <div class="mt-6">
                    <a asp-page="/Pricing" class="text-sm text-lumina-sage hover:text-lumina-terracotta">Top up your practice →</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Next Class Hero -->
    <div class="lumina-card p-8 mb-8 bg-gradient-to-br from-white to-lumina-sage-light/30">
        <div class="flex items-center justify-between">
            <div>
                <div class="text-xs uppercase tracking-widest text-lumina-sage">NEXT UP</div>
                @if (Model.NextBooking != null)
                {
                    <div class="text-4xl font-medium tracking-tight mt-2">@Model.NextBooking.ScheduledClass.ClassType.Name</div>
                    <div class="mt-1 text-xl text-lumina-charcoal/80">@Model.NextBooking.ScheduledClass.StartUtc.ToString("f") with @Model.NextBooking.ScheduledClass.Instructor.Name</div>
                }
                else
                {
                    <div class="text-4xl font-medium tracking-tight mt-2 text-lumina-charcoal/60">No class booked yet</div>
                }
            </div>
            <a asp-page="/Schedule" class="btn-lumina btn-lumina-primary px-10 py-4 text-lg hidden md:block">Change or add</a>
        </div>
    </div>

    <!-- Upcoming + Visual History -->
    <div class="grid md:grid-cols-5 gap-5">
        <div class="md:col-span-3">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-2xl font-medium tracking-tight">Your upcoming practice</h2>
            </div>

            @if (Model.UpcomingBookings.Any())
            {
                <div class="space-y-3">
                    @foreach (var b in Model.UpcomingBookings)
                    {
                        <div class="premium-card lumina-card px-6 py-5 flex items-center justify-between group">
                            <div class="flex items-center gap-x-4">
                                <div class="w-14 h-14 rounded-2xl overflow-hidden flex-shrink-0">
                                    <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=200" class="w-full h-full object-cover" alt="">
                                </div>
                                <div>
                                    <div class="font-medium">@b.ScheduledClass.ClassType.Name</div>
                                    <div class="text-sm text-lumina-charcoal/70">@b.ScheduledClass.StartUtc.ToString("f") with @b.ScheduledClass.Instructor.Name</div>
                                </div>
                            </div>
                            <a asp-page="/Schedule" class="text-sm text-lumina-sage group-hover:text-lumina-terracotta transition">Manage →</a>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="premium-card lumina-card p-8 text-center">
                    <div class="text-6xl mb-4">🌿</div>
                    <div class="text-xl font-medium">Your calendar is beautifully open.</div>
                    <a asp-page="/Schedule" class="mt-4 inline-block text-lumina-sage font-medium hover:text-lumina-terracotta">Find something that calls to you →</a>
                </div>
            }
        </div>

        <div class="md:col-span-2 lumina-card p-7">
            <div class="text-xs uppercase tracking-widest text-lumina-sage mb-3">YOUR PRACTICE THIS MONTH</div>
            <div class="space-y-4 text-sm">
                <div class="flex justify-between"><span>Reformer Pilates</span><span class="font-medium">7</span></div>
                <div class="flex justify-between"><span>Restorative Yoga</span><span class="font-medium">4</span></div>
                <div class="flex justify-between"><span>Gentle Flow</span><span class="font-medium">1</span></div>
            </div>
            <div class="mt-6 pt-6 border-t text-xs text-lumina-charcoal/60">Your body is asking for more restorative work lately. Listen to it.</div>
        </div>
    </div>
</div>