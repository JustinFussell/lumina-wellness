@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero -->
<section class="relative min-h-[92vh] flex items-center justify-center bg-lumina-cream overflow-hidden">
    <div class="max-w-5xl mx-auto px-6 text-center pt-12 pb-20">
        <div class="inline-flex items-center gap-x-2 rounded-full bg-white/70 px-4 py-1 text-xs tracking-[2px] text-lumina-sage mb-6 border border-lumina-sage-light">
            RONDEBOSCH • CAPE TOWN
        </div>
        
        <h1 class="text-6xl md:text-7xl font-light tracking-[-2.5px] leading-[0.92] text-lumina-charcoal mb-6">
            Move with<br />presence.<br />
            <span class="text-lumina-sage">Find your light.</span>
        </h1>
        
        <p class="max-w-md mx-auto text-xl text-lumina-charcoal/70 mb-10">
            A sanctuary for Pilates, yoga, and mindful movement in the heart of Rondebosch — 
            where clinical care and soulful practice meet.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a asp-page="/Schedule" 
               class="lumina-btn-primary inline-flex items-center justify-center text-lg px-10 py-4">
                View the schedule
            </a>
            <a asp-page="/Account/Register" 
               class="inline-flex items-center justify-center text-lg px-8 py-4 rounded-2xl border-2 border-lumina-charcoal/80 hover:bg-lumina-charcoal hover:text-white transition-all">
                Begin your practice
            </a>
        </div>
        
        <div class="mt-8 text-xs text-lumina-charcoal/50 tracking-widest">
            IN THE SAME BUILDING AS PHYSIOTHERAPY CARE
        </div>
    </div>
    
    <!-- Subtle decorative element -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 text-lumina-sage/40 text-[10px] tracking-[3px]">
        SCROLL TO BEGIN
    </div>
</section>

<!-- The Lumina Approach -->
<section class="max-w-5xl mx-auto px-6 py-20">
    <div class="grid md:grid-cols-12 gap-x-12 items-center">
        <div class="md:col-span-5">
            <div class="uppercase tracking-[3px] text-xs text-lumina-sage mb-3">Our Philosophy</div>
            <h2 class="section-title text-5xl tracking-[-1.5px] leading-none">
                Movement that<br />actually serves you.
            </h2>
        </div>
        <div class="md:col-span-7 mt-8 md:mt-0 text-[17px] leading-relaxed text-lumina-charcoal/80 space-y-6">
            <p>Lumina is not another studio that counts reps. We create space for you to arrive exactly as you are — whether you’re recovering from injury, returning to your body after years away, or simply seeking a quieter kind of strength.</p>
            <p>Every class is designed with care, modifications, and genuine accessibility in mind. Our teachers work closely with the physiotherapists in our building so your movement practice supports your whole health.</p>
        </div>
    </div>
</section>

<!-- Class Types Teaser -->
<section class="bg-white py-16 border-y border-lumina-sage-light">
    <div class="max-w-6xl mx-auto px-6">
        <div class="flex items-end justify-between mb-10">
            <div>
                <div class="text-xs tracking-[3px] text-lumina-sage">WHAT WE OFFER</div>
                <h3 class="section-title text-4xl tracking-tight mt-1">Classes for every body and every season.</h3>
            </div>
            <a asp-page="/Schedule" class="hidden md:block text-sm text-lumina-sage hover:text-lumina-terracotta">See full schedule →</a>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
            @* Reformer Pilates *@
            <div class="lumina-card p-7 group">
                <div class="text-lumina-terracotta text-sm tracking-widest mb-1">RESTORATIVE STRENGTH</div>
                <h4 class="text-2xl font-medium tracking-tight mb-3">Reformer Pilates</h4>
                <p class="text-lumina-charcoal/70 text-[15px] leading-relaxed">Intelligent, precise work on the reformer. Perfect for building deep core strength, improving posture, and moving with ease — whether you’re brand new or returning after time away.</p>
                <div class="mt-5 text-xs text-lumina-sage">Chair options • Prenatal safe • All levels</div>
            </div>
            
            @* Restorative Yoga *@
            <div class="lumina-card p-7 group">
                <div class="text-lumina-terracotta text-sm tracking-widest mb-1">DEEP REST + RELEASE</div>
                <h4 class="text-2xl font-medium tracking-tight mb-3">Restorative Yoga</h4>
                <p class="text-lumina-charcoal/70 text-[15px] leading-relaxed">Supported, long-held poses with blankets, bolsters and gentle guidance. Ideal for nervous system regulation, chronic pain, or simply needing to be held by the practice.</p>
                <div class="mt-5 text-xs text-lumina-sage">Low sensory option • Chair available • All bodies</div>
            </div>

            @* Mat Pilates + More *@
            <div class="lumina-card p-7 group">
                <div class="text-lumina-terracotta text-sm tracking-widest mb-1">FUNCTIONAL + EMBODIED</div>
                <h4 class="text-2xl font-medium tracking-tight mb-3">Mat Pilates &amp; Contemporary Flow</h4>
                <p class="text-lumina-charcoal/70 text-[15px] leading-relaxed">Grounded, intelligent movement that translates directly into daily life. We also offer prenatal, menopause-aware, and adaptive classes.</p>
                <div class="mt-5 text-xs text-lumina-sage">Adaptive • Queer &amp; trans welcoming • All bodies</div>
            </div>
        </div>
        
        <div class="text-center mt-8 md:hidden">
            <a asp-page="/Schedule" class="text-sm text-lumina-sage">See the full schedule →</a>
        </div>
    </div>
</section>

<!-- Trust / Location Signal -->
<section class="max-w-4xl mx-auto px-6 py-16 text-center">
    <div class="max-w-md mx-auto">
        <p class="text-lumina-charcoal/70">We share our building with experienced physiotherapists. Many of our members come through referral, and our teachers and the clinical team communicate regularly so your movement practice truly supports your recovery and long-term health.</p>
        <div class="mt-6 text-xs uppercase tracking-widest text-lumina-sage">Clinical Care • Soulful Movement • One Building</div>
    </div>
</section>
