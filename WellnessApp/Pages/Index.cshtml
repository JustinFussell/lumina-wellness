@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero — Really Modern 2026 Composition -->
<section class="relative min-h-[100dvh] flex items-center justify-center overflow-hidden">
    <!-- Background + modern subtle gradient layers -->
    <div class="absolute inset-0 pointer-events-none">
        <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=2200" 
             alt="Serene woman practicing mindful movement in soft natural light"
             class="w-full h-full object-cover parallax-bg">
        <div class="absolute inset-0 bg-[radial-gradient(at_50%_30%,rgba(47,44,39,0.35)_0%,transparent_50%)]"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-lumina-charcoal/45 via-lumina-charcoal/55 to-lumina-charcoal/85"></div>
    </div>
    
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center pt-16 pb-20">
        <!-- Modern location badge -->
        <div class="inline-flex items-center gap-x-2.5 rounded-full bg-white/85 backdrop-blur-xl px-6 py-2 text-[10px] tracking-[3.5px] text-lumina-sage mb-9 border border-white/70 shadow-sm">
            <span class="inline-block w-1 h-1 rounded-full bg-lumina-gold"></span>
            RONDEBOSCH • CAPE TOWN
        </div>
        
        <h1 class="text-[68px] md:text-[96px] font-light tracking-[-5.2px] leading-[0.86] text-white mb-7">
            Move with<br>presence.<br>
            <span class="text-lumina-cream tracking-[-4.8px]">Find your light.</span>
        </h1>
        
        <p class="max-w-md mx-auto text-[21px] text-white mb-11 font-light tracking-[-0.2px]">
            A sanctuary where clinical care and soulful movement exist in the same breath.
        </p>

        <!-- Modern primary action cluster -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a asp-page="/Schedule" 
               class="group inline-flex items-center justify-center gap-x-2.5 bg-white text-lumina-charcoal font-medium text-[15px] px-9 py-[17px] rounded-3xl shadow-xl hover:shadow-2xl active:scale-[0.985] transition-all">
                Explore the schedule
                <span class="text-lg leading-none group-hover:translate-x-0.5 transition">→</span>
            </a>
            <a asp-page="/Account/Register" 
               class="inline-flex items-center justify-center text-[15px] px-8 py-[17px] rounded-3xl border border-white/75 text-white hover:bg-white/10 hover:text-white backdrop-blur-lg transition-all font-medium tracking-[-0.1px]">
                Begin your practice
            </a>
        </div>
        
        <div class="mt-14 text-[10px] tracking-[3px] text-white/80 font-medium">
            IN THE SAME BUILDING AS PHYSIOTHERAPY
        </div>
    </div>
    
    <!-- Elegant modern scroll prompt -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-0 flex flex-col items-center text-white/70 text-[10px] tracking-[4px]">
        SCROLL TO BEGIN YOUR JOURNEY
        <div class="h-px w-5 bg-white/50 mt-3"></div>
    </div>
</section>

<!-- The Lumina Approach -->
<section class="max-w-5xl mx-auto px-6 py-20 reveal">
    <div class="grid md:grid-cols-12 gap-x-12 items-center">
        <div class="md:col-span-5">
            <div class="uppercase tracking-[3px] text-xs text-lumina-sage mb-3">Our Philosophy</div>
            <h2 class="section-title text-5xl tracking-[-1.5px] leading-none">
                Movement that<br />actually serves you.
            </h2>
        </div>
        <div class="md:col-span-7 mt-8 md:mt-0 text-[17px] leading-relaxed text-lumina-charcoal space-y-6">
            <p>Lumina is not another studio that counts reps. We create space for you to arrive exactly as you are — whether you’re recovering from injury, returning to your body after years away, or simply seeking a quieter kind of strength.</p>
            <p>Every class is designed with care, modifications, and genuine accessibility in mind. Our teachers work closely with the physiotherapists in our building so your movement practice supports your whole health.</p>
        </div>
    </div>
</section>

<!-- Classes with Images + Wow Factor -->
<section class="py-20 bg-white reveal reveal-delay-1">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-end mb-10">
            <div>
                <div class="text-xs tracking-[3px] text-lumina-sage">WHAT WE OFFER</div>
                <h3 class="section-title text-5xl tracking-tight mt-1">Classes for every body.</h3>
            </div>
            <a asp-page="/Schedule" class="hidden md:block text-sm text-lumina-sage hover:text-lumina-terracotta font-medium">See full schedule →</a>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Reformer -->
            <div class="premium-card group rounded-3xl overflow-hidden bg-white elegant-shadow border border-lumina-sage-light/50">
                <div class="relative h-56 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?q=80&w=800" 
                         class="class-image w-full h-full object-cover" alt="Reformer Pilates in serene studio">
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
                    <div class="absolute bottom-4 left-4 text-white">
                        <div class="text-xs tracking-widest opacity-80">RESTORATIVE STRENGTH</div>
                        <div class="text-2xl font-medium tracking-tight">Reformer Pilates</div>
                    </div>
                </div>
                <div class="p-6 text-sm text-lumina-charcoal/80">
                    Precise, intelligent work on the reformer. Perfect for core strength and graceful movement.
                    <div class="mt-4 flex flex-wrap gap-1.5">
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Chair option</span>
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Prenatal safe</span>
                    </div>
                </div>
            </div>

            <!-- Restorative Yoga -->
            <div class="premium-card group rounded-3xl overflow-hidden bg-white elegant-shadow border border-lumina-sage-light/50">
                <div class="relative h-56 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=800" 
                         class="class-image w-full h-full object-cover" alt="Woman in restorative yoga pose with props">
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
                    <div class="absolute bottom-4 left-4 text-white">
                        <div class="text-xs tracking-widest opacity-80">DEEP REST + RELEASE</div>
                        <div class="text-2xl font-medium tracking-tight">Restorative Yoga</div>
                    </div>
                </div>
                <div class="p-6 text-sm text-lumina-charcoal/80">
                    Long-held, fully supported poses. The ultimate nervous system reset.
                    <div class="mt-4 flex flex-wrap gap-1.5">
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Low sensory</span>
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">All bodies</span>
                    </div>
                </div>
            </div>

            <!-- Mat Flow -->
            <div class="premium-card group rounded-3xl overflow-hidden bg-white elegant-shadow border border-lumina-sage-light/50">
                <div class="relative h-56 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?q=80&w=800" 
                         class="class-image w-full h-full object-cover" alt="Group in mindful mat Pilates">
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
                    <div class="absolute bottom-4 left-4 text-white">
                        <div class="text-xs tracking-widest opacity-80">FUNCTIONAL + EMBODIED</div>
                        <div class="text-2xl font-medium tracking-tight">Mat Pilates Flow</div>
                    </div>
                </div>
                <div class="p-6 text-sm text-lumina-charcoal/80">
                    Grounded, intelligent movement that translates to daily life.
                    <div class="mt-4 flex flex-wrap gap-1.5">
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Adaptive</span>
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">All levels</span>
                    </div>
                </div>
            </div>

            <!-- Gentle Yoga -->
            <div class="premium-card group rounded-3xl overflow-hidden bg-white elegant-shadow border border-lumina-sage-light/50">
                <div class="relative h-56 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=800" 
                         class="class-image w-full h-full object-cover" alt="Peaceful yoga practice in natural setting">
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
                    <div class="absolute bottom-4 left-4 text-white">
                        <div class="text-xs tracking-widest opacity-80">MINDFUL MOVEMENT</div>
                        <div class="text-2xl font-medium tracking-tight">Gentle Vinyasa</div>
                    </div>
                </div>
                <div class="p-6 text-sm text-lumina-charcoal/80">
                    Slow, breath-led flow with endless modifications.
                    <div class="mt-4 flex flex-wrap gap-1.5">
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Beginner friendly</span>
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Chair option</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Find Your Flow - Interactive Quiz (Wow Interactivity) -->
<section class="py-20 serene-gradient" x-data="flowQuiz()">
    <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="uppercase tracking-[3px] text-xs text-lumina-sage mb-2">NOT SURE WHERE TO START?</div>
        <h3 class="section-title text-5xl tracking-tight mb-4">Find Your Flow</h3>
        <p class="text-lumina-charcoal/70 mb-10 max-w-sm mx-auto">Answer 4 quick questions. We'll recommend the perfect class for you today.</p>

        <div x-show="!result" class="max-w-md mx-auto">
            <!-- Question 1 -->
            <div x-show="step === 1" class="text-left">
                <div class="font-medium mb-4">How are you feeling in your body today?</div>
                <div class="space-y-2">
                    <button x-on:click="answer(1, 'restorative')" class="w-full text-left px-6 py-4 rounded-2xl border hover:border-lumina-sage transition-all">I need deep rest and restoration</button>
                    <button x-on:click="answer(1, 'strength')" class="w-full text-left px-6 py-4 rounded-2xl border hover:border-lumina-sage transition-all">I want to feel strong and grounded</button>
                    <button x-on:click="answer(1, 'flow')" class="w-full text-left px-6 py-4 rounded-2xl border hover:border-lumina-sage transition-all">I have energy and want to move with intention</button>
                </div>
            </div>
            
            <!-- More questions would go here in a full version. For wow, simplified to one impactful question for demo -->
            
            <div x-show="step > 1" class="mt-8 p-8 bg-white rounded-3xl elegant-shadow">
                <div class="text-lumina-sage text-sm mb-2">YOUR RECOMMENDATION</div>
                <div class="text-3xl font-medium tracking-tight mb-2" x-text="recommendation"></div>
                <p class="text-lumina-charcoal/70" x-text="recommendationDesc"></p>
                
                <a :href="recommendationLink" class="mt-6 inline-block lumina-btn-primary px-8 py-3">View this class →</a>
            </div>
        </div>
    </div>
</section>

<!-- Our Teachers -->
<section class="py-20 bg-white reveal reveal-delay-2">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center mb-12">
            <div class="text-xs tracking-[3px] text-lumina-sage">THE PEOPLE</div>
            <h3 class="section-title text-5xl tracking-tight mt-2">Meet our teachers</h3>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
            <div class="text-center group">
                <div class="w-40 h-40 mx-auto rounded-3xl overflow-hidden mb-6 elegant-shadow">
                    <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?q=80&w=600" class="wellness-image w-full h-full object-cover" alt="Thandi Mokoena">
                </div>
                <div class="font-medium text-xl">Thandi Mokoena</div>
                <div class="text-lumina-sage">Founder • Reformer &amp; Restorative</div>
                <p class="mt-3 text-sm text-lumina-charcoal/70 max-w-xs mx-auto">15 years guiding people back into their bodies with precision and deep care.</p>
            </div>

            <div class="text-center group">
                <div class="w-40 h-40 mx-auto rounded-3xl overflow-hidden mb-6 elegant-shadow">
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?q=80&w=600" class="wellness-image w-full h-full object-cover" alt="Liam van der Berg">
                </div>
                <div class="font-medium text-xl">Liam van der Berg</div>
                <div class="text-lumina-sage">Mat Flow &amp; Functional Movement</div>
                <p class="mt-3 text-sm text-lumina-charcoal/70 max-w-xs mx-auto">Passionate about helping people move without pain and build lasting strength.</p>
            </div>

            <div class="text-center group">
                <div class="w-40 h-40 mx-auto rounded-3xl overflow-hidden mb-6 elegant-shadow">
                    <img src="https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=600" class="wellness-image w-full h-full object-cover" alt="Aisha Khan">
                </div>
                <div class="font-medium text-xl">Aisha Khan</div>
                <div class="text-lumina-sage">Adaptive &amp; Inclusive Yoga</div>
                <p class="mt-3 text-sm text-lumina-charcoal/70 max-w-xs mx-auto">Specialist in creating accessible practices for every body and every ability.</p>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Carousel -->
<section class="py-20 serene-gradient reveal reveal-delay-1" x-data="{ current: 0, testimonials: [
    { quote: 'Lumina is the only place where I feel completely safe to move at my own pace. The teachers see me.', name: 'Elena', detail: '3 years practicing' },
    { quote: 'After my injury, the physio downstairs referred me here. The way they work together changed everything for me.', name: 'Marcus', detail: 'Reformer student' },
    { quote: 'The space itself feels like an exhale. I leave every class more like myself than when I arrived.', name: 'Nadia', detail: 'Restorative regular' }
] }">
    <div class="max-w-3xl mx-auto px-6">
        <div class="text-xs tracking-[3px] text-lumina-sage text-center mb-4">WHAT PEOPLE SAY</div>
        
        <div class="relative min-h-[180px]">
            <template x-for="(t, index) in testimonials" :key="index">
                <div x-show="current === index" 
                     x-transition:enter="transition ease-out duration-300"
                     x-transition:enter-start="opacity-0 translate-y-4"
                     x-transition:enter-end="opacity-100 translate-y-0"
                     class="absolute inset-0 text-center">
                    <p class="text-2xl md:text-3xl leading-tight font-light" x-text="t.quote"></p>
                    <div class="mt-6">
                        <span class="font-medium" x-text="t.name"></span>
                        <span class="text-lumina-charcoal/60" x-text="'— ' + t.detail"></span>
                    </div>
                </div>
            </template>
        </div>

        <!-- Carousel Controls -->
        <div class="flex justify-center gap-3 mt-8">
            <template x-for="(t, index) in testimonials" :key="index">
                <button x-on:click="current = index"
                        class="w-2.5 h-2.5 rounded-full transition-all"
                        :class="current === index ? 'bg-lumina-sage scale-125' : 'bg-lumina-sage/30 hover:bg-lumina-sage/50'">
                </button>
            </template>
        </div>
    </div>
</section>

<!-- Recent Moments / Community Light -->
<section class="py-20 bg-white reveal">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex items-end justify-between mb-8">
            <div>
                <div class="text-xs tracking-[3px] text-lumina-sage">IN THE STUDIO</div>
                <h3 class="section-title text-5xl tracking-tight mt-1">Recent moments</h3>
            </div>
            <a href="#" class="hidden md:block text-sm text-lumina-sage hover:text-lumina-terracotta">Follow us on Instagram →</a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div class="group overflow-hidden rounded-3xl aspect-[4/3] relative">
                <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=800" class="wellness-image w-full h-full object-cover" alt="Morning restorative circle">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white text-sm">Morning restorative circle with Aisha</div>
            </div>
            <div class="group overflow-hidden rounded-3xl aspect-[4/3] relative">
                <img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?q=80&w=800" class="wellness-image w-full h-full object-cover" alt="Reformer session">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white text-sm">Thandi guiding a small group on the reformers</div>
            </div>
            <div class="group overflow-hidden rounded-3xl aspect-[4/3] relative">
                <img src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=800" class="wellness-image w-full h-full object-cover" alt="Sunset gentle flow">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white text-sm">Golden hour gentle flow on the deck</div>
            </div>
            <div class="group overflow-hidden rounded-3xl aspect-[4/3] relative">
                <img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?q=80&w=800" class="wellness-image w-full h-full object-cover" alt="Community after class">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white text-sm">Tea and conversation after Saturday class</div>
            </div>
        </div>
    </div>
</section>

<!-- Final CTA -->
<section class="py-24 text-center bg-white reveal reveal-delay-2">
    <div class="max-w-xl mx-auto px-6">
        <h3 class="section-title text-5xl tracking-tight">Ready to move with presence?</h3>
        <p class="mt-4 text-xl text-lumina-charcoal/70">Come experience Lumina for yourself.</p>
        
        <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
            <a asp-page="/Schedule" class="btn-lumina btn-lumina-primary px-10 py-4 text-lg">View the schedule</a>
            <a asp-page="/Account/Register" class="btn-lumina btn-lumina-secondary px-10 py-4 text-lg">Join as a member</a>
        </div>
    </div>
</section>

<script>
function flowQuiz() {
  return {
    step: 1,
    answers: {},
    recommendation: '',
    recommendationDesc: '',
    recommendationLink: '/Schedule',
    
    answer(q, value) {
      this.answers[q] = value;
      
      if (q === 1) {
        if (value === 'restorative') {
          this.recommendation = "Restorative Yoga";
          this.recommendationDesc = "Your body is asking for deep rest. This class will hold you.";
          this.recommendationLink = '/Schedule?modality=Yoga';
        } else if (value === 'strength') {
          this.recommendation = "Reformer Pilates";
          this.recommendationDesc = "Time to build quiet power from the inside out.";
          this.recommendationLink = '/Schedule?modality=Pilates';
        } else {
          this.recommendation = "Mat Pilates Flow";
          this.recommendationDesc = "You have energy. Let's move with precision and grace.";
          this.recommendationLink = '/Schedule?modality=Pilates';
        }
        this.step = 2;
      }
    }
  }
}
</script>
