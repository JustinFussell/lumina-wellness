@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero - Maximum Wow -->
<section class="relative min-h-[100dvh] flex items-center justify-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0">
        <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=2000" 
             alt="Serene woman practicing mindful movement in soft natural light"
             class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-b from-lumina-charcoal/40 via-lumina-charcoal/30 to-lumina-cream/95"></div>
    </div>
    
    <div class="relative max-w-5xl mx-auto px-6 text-center pt-20 pb-16">
        <div class="inline-flex items-center gap-x-2 rounded-full bg-white/90 backdrop-blur-md px-5 py-1.5 text-xs tracking-[3px] text-lumina-sage mb-8 border border-white/60 shadow-sm">
            RONDEBOSCH • CAPE TOWN
        </div>
        
        <h1 class="text-7xl md:text-[92px] font-light tracking-[-4.5px] leading-[0.88] text-white mb-8 drop-shadow-sm">
            Move with<br>presence.<br>
            <span class="text-lumina-cream">Find your light.</span>
        </h1>
        
        <p class="max-w-lg mx-auto text-2xl text-white/90 mb-12 font-light tracking-tight">
            A sanctuary for Pilates, yoga, and mindful movement — where clinical care and soulful practice meet.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a asp-page="/Schedule" 
               class="group inline-flex items-center justify-center gap-x-3 bg-white text-lumina-charcoal font-medium text-lg px-10 py-4 rounded-3xl shadow-xl hover:shadow-2xl transition-all active:scale-[0.985]">
                Explore the schedule
                <span class="group-hover:translate-x-0.5 transition">→</span>
            </a>
            <a asp-page="/Account/Register" 
               class="inline-flex items-center justify-center text-lg px-9 py-4 rounded-3xl border border-white/70 text-white hover:bg-white hover:text-lumina-charcoal backdrop-blur transition-all font-medium">
                Begin your practice
            </a>
        </div>
        
        <div class="mt-10 flex justify-center gap-x-8 text-xs tracking-[2px] text-white/70">
            <div>IN THE SAME BUILDING AS PHYSIOTHERAPY</div>
        </div>
    </div>
    
    <!-- Scroll Indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center text-white/60 text-xs tracking-[3px]">
        <div>SCROLL TO BEGIN</div>
        <div class="h-px w-6 bg-white/40 mt-2"></div>
    </div>
</section>

<!-- The Lumina Approach -->
<section class="max-w-5xl mx-auto px-6 py-20">
    <div class="grid md:grid-cols-12 gap-x-12 items-center">
        <div class="md:col-span-5">
            <div class="uppercase tracking-[3px] text-xs text-lumina-sage mb-3">Our Philosophy</div>
            <h2 class="section-title text-5xl tracking-[-1.5px] leading-none">
                Movement that<br />actually serves you.
            </h2>
        </div>
        <div class="md:col-span-7 mt-8 md:mt-0 text-[17px] leading-relaxed text-lumina-charcoal/80 space-y-6">
            <p>Lumina is not another studio that counts reps. We create space for you to arrive exactly as you are — whether you’re recovering from injury, returning to your body after years away, or simply seeking a quieter kind of strength.</p>
            <p>Every class is designed with care, modifications, and genuine accessibility in mind. Our teachers work closely with the physiotherapists in our building so your movement practice supports your whole health.</p>
        </div>
    </div>
</section>

<!-- Classes with Images + Wow Factor -->
<section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6">
        <div class="flex justify-between items-end mb-10">
            <div>
                <div class="text-xs tracking-[3px] text-lumina-sage">WHAT WE OFFER</div>
                <h3 class="section-title text-5xl tracking-tight mt-1">Classes for every body.</h3>
            </div>
            <a asp-page="/Schedule" class="hidden md:block text-sm text-lumina-sage hover:text-lumina-terracotta font-medium">See full schedule →</a>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Reformer -->
            <div class="premium-card group rounded-3xl overflow-hidden bg-white elegant-shadow border border-lumina-sage-light/50">
                <div class="relative h-56 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?q=80&w=800" 
                         class="class-image w-full h-full object-cover" alt="Reformer Pilates in serene studio">
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
                    <div class="absolute bottom-4 left-4 text-white">
                        <div class="text-xs tracking-widest opacity-80">RESTORATIVE STRENGTH</div>
                        <div class="text-2xl font-medium tracking-tight">Reformer Pilates</div>
                    </div>
                </div>
                <div class="p-6 text-sm text-lumina-charcoal/80">
                    Precise, intelligent work on the reformer. Perfect for core strength and graceful movement.
                    <div class="mt-4 flex flex-wrap gap-1.5">
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Chair option</span>
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Prenatal safe</span>
                    </div>
                </div>
            </div>

            <!-- Restorative Yoga -->
            <div class="premium-card group rounded-3xl overflow-hidden bg-white elegant-shadow border border-lumina-sage-light/50">
                <div class="relative h-56 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?q=80&w=800" 
                         class="class-image w-full h-full object-cover" alt="Woman in restorative yoga pose with props">
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
                    <div class="absolute bottom-4 left-4 text-white">
                        <div class="text-xs tracking-widest opacity-80">DEEP REST + RELEASE</div>
                        <div class="text-2xl font-medium tracking-tight">Restorative Yoga</div>
                    </div>
                </div>
                <div class="p-6 text-sm text-lumina-charcoal/80">
                    Long-held, fully supported poses. The ultimate nervous system reset.
                    <div class="mt-4 flex flex-wrap gap-1.5">
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Low sensory</span>
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">All bodies</span>
                    </div>
                </div>
            </div>

            <!-- Mat Flow -->
            <div class="premium-card group rounded-3xl overflow-hidden bg-white elegant-shadow border border-lumina-sage-light/50">
                <div class="relative h-56 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1518611012118-696072aa579a?q=80&w=800" 
                         class="class-image w-full h-full object-cover" alt="Group in mindful mat Pilates">
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
                    <div class="absolute bottom-4 left-4 text-white">
                        <div class="text-xs tracking-widest opacity-80">FUNCTIONAL + EMBODIED</div>
                        <div class="text-2xl font-medium tracking-tight">Mat Pilates Flow</div>
                    </div>
                </div>
                <div class="p-6 text-sm text-lumina-charcoal/80">
                    Grounded, intelligent movement that translates to daily life.
                    <div class="mt-4 flex flex-wrap gap-1.5">
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Adaptive</span>
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">All levels</span>
                    </div>
                </div>
            </div>

            <!-- Gentle Yoga -->
            <div class="premium-card group rounded-3xl overflow-hidden bg-white elegant-shadow border border-lumina-sage-light/50">
                <div class="relative h-56 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1506126613408-eca07ce68773?q=80&w=800" 
                         class="class-image w-full h-full object-cover" alt="Peaceful yoga practice in natural setting">
                    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/60"></div>
                    <div class="absolute bottom-4 left-4 text-white">
                        <div class="text-xs tracking-widest opacity-80">MINDFUL MOVEMENT</div>
                        <div class="text-2xl font-medium tracking-tight">Gentle Vinyasa</div>
                    </div>
                </div>
                <div class="p-6 text-sm text-lumina-charcoal/80">
                    Slow, breath-led flow with endless modifications.
                    <div class="mt-4 flex flex-wrap gap-1.5">
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Beginner friendly</span>
                        <span class="text-[10px] px-3 py-1 rounded-full bg-lumina-sage-light text-lumina-charcoal">Chair option</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Find Your Flow - Interactive Quiz (Wow Interactivity) -->
<section class="py-20 serene-gradient" x-data="flowQuiz()">
    <div class="max-w-3xl mx-auto px-6 text-center">
        <div class="uppercase tracking-[3px] text-xs text-lumina-sage mb-2">NOT SURE WHERE TO START?</div>
        <h3 class="section-title text-5xl tracking-tight mb-4">Find Your Flow</h3>
        <p class="text-lumina-charcoal/70 mb-10 max-w-sm mx-auto">Answer 4 quick questions. We'll recommend the perfect class for you today.</p>

        <div x-show="!result" class="max-w-md mx-auto">
            <!-- Question 1 -->
            <div x-show="step === 1" class="text-left">
                <div class="font-medium mb-4">How are you feeling in your body today?</div>
                <div class="space-y-2">
                    <button @click="answer(1, 'restorative')" class="w-full text-left px-6 py-4 rounded-2xl border hover:border-lumina-sage transition-all">I need deep rest and restoration</button>
                    <button @click="answer(1, 'strength')" class="w-full text-left px-6 py-4 rounded-2xl border hover:border-lumina-sage transition-all">I want to feel strong and grounded</button>
                    <button @click="answer(1, 'flow')" class="w-full text-left px-6 py-4 rounded-2xl border hover:border-lumina-sage transition-all">I have energy and want to move with intention</button>
                </div>
            </div>
            
            <!-- More questions would go here in a full version. For wow, simplified to one impactful question for demo -->
            
            <div x-show="step > 1" class="mt-8 p-8 bg-white rounded-3xl elegant-shadow">
                <div class="text-lumina-sage text-sm mb-2">YOUR RECOMMENDATION</div>
                <div class="text-3xl font-medium tracking-tight mb-2" x-text="recommendation"></div>
                <p class="text-lumina-charcoal/70" x-text="recommendationDesc"></p>
                
                <a :href="recommendationLink" class="mt-6 inline-block lumina-btn-primary px-8 py-3">View this class →</a>
            </div>
        </div>
    </div>
</section>

<!-- Trust / Location Signal -->
<section class="max-w-4xl mx-auto px-6 py-16 text-center">
    <div class="max-w-md mx-auto">
        <p class="text-lumina-charcoal/70">We share our building with experienced physiotherapists. Many of our members come through referral, and our teachers and the clinical team communicate regularly so your movement practice truly supports your recovery and long-term health.</p>
        <div class="mt-6 text-xs uppercase tracking-widest text-lumina-sage">Clinical Care • Soulful Movement • One Building</div>
    </div>
</section>

<script>
function flowQuiz() {
  return {
    step: 1,
    answers: {},
    recommendation: '',
    recommendationDesc: '',
    recommendationLink: '/Schedule',
    
    answer(q, value) {
      this.answers[q] = value;
      
      if (q === 1) {
        if (value === 'restorative') {
          this.recommendation = "Restorative Yoga";
          this.recommendationDesc = "Your body is asking for deep rest. This class will hold you.";
          this.recommendationLink = '/Schedule?modality=Yoga';
        } else if (value === 'strength') {
          this.recommendation = "Reformer Pilates";
          this.recommendationDesc = "Time to build quiet power from the inside out.";
          this.recommendationLink = '/Schedule?modality=Pilates';
        } else {
          this.recommendation = "Mat Pilates Flow";
          this.recommendationDesc = "You have energy. Let's move with precision and grace.";
          this.recommendationLink = '/Schedule?modality=Pilates';
        }
        this.step = 2;
      }
    }
  }
}
</script>
