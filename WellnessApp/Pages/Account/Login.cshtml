@page
@model Lumina.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log In";
}

<div class="max-w-sm mx-auto px-6 py-12">
    <h1 class="section-title text-4xl text-center">Welcome back</h1>

    <form method="post" class="mt-8 space-y-5">
        <div>
            <label class="block text-sm mb-1.5">Email</label>
            <input asp-for="Input.Email" class="w-full rounded-2xl border border-lumina-sage-light px-4 py-3" />
        </div>
        <div>
            <label class="block text-sm mb-1.5">Password</label>
            <input asp-for="Input.Password" type="password" class="w-full rounded-2xl border border-lumina-sage-light px-4 py-3" />
        </div>

        <button type="submit" class="w-full lumina-btn-primary py-3">Log in</button>
    </form>

    <p class="mt-6 text-center text-sm">New here? <a asp-page="/Account/Register" class="text-lumina-sage">Create an account</a></p>
</div>