@page
@model Lumina.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Log In";
}

<div class="max-w-sm mx-auto px-6 py-14">
    <div class="text-center mb-8">
        <div class="text-[10px] tracking-[3.5px] text-lumina-sage">WELCOME BACK</div>
        <h1 class="text-4xl font-light tracking-tight mt-1">Log in to your practice</h1>
    </div>

    <form method="post" class="space-y-4 bg-white border border-lumina-sage-light/60 rounded-3xl p-7">
        <div>
            <label class="block text-xs tracking-widest text-lumina-sage mb-1.5">EMAIL</label>
            <input asp-for="Input.Email" class="w-full rounded-2xl border border-lumina-sage-light bg-white px-5 py-3.5 focus:border-lumina-sage transition" />
        </div>
        <div>
            <label class="block text-xs tracking-widest text-lumina-sage mb-1.5">PASSWORD</label>
            <input asp-for="Input.Password" type="password" class="w-full rounded-2xl border border-lumina-sage-light bg-white px-5 py-3.5 focus:border-lumina-sage transition" />
        </div>

        <button type="submit" class="w-full btn-lumina btn-lumina-primary py-3.5 mt-1">Log in</button>
    </form>

    <p class="mt-6 text-center text-sm text-lumina-charcoal/60">
        New here? <a asp-page="/Account/Register" class="text-lumina-sage font-medium">Create an account</a>
    </p>
</div>